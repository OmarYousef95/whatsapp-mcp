{
  "name": "whatsapp-mcp",
  "version": "0.1.0",
  "description": "MCP server for personal WhatsApp accounts — lets Claude and other MCP clients send WhatsApp messages. No browser, no Business API: pairs like WhatsApp Web via one QR scan.",
  "type": "module",
  "bin": {
    "whatsapp-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "login": "tsx src/index.ts login",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "whatsapp",
    "claude",
    "baileys",
    "ai"
  ],
  "author": "Omar Yousef",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@whiskeysockets/baileys": "^7.0.0-rc13",
    "pino": "^10.3.1",
    "qrcode-terminal": "^0.12.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/qrcode-terminal": "^0.12.2",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
